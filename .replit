modules = ["python-3.11", "nodejs-20", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[agent]
expertMode = true
integrations = ["github:1.0.0", "javascript_object_storage:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "smoke"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backfill Retry"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Fast Sync"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Verify Units"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Fill PK"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port app:app"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "smoke"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/smoke_test.py"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python tests/api_test.py"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Backfill Retry"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "nice -n 19 python -u sync_batch.py --retry-failures --master-only --sleep 0.8"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Fast Sync"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -u sync_batch.py --months 60 --master-only"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Verify Units"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -u verify_units.py excluded_small_buildings.csv"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Fill PK"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -u backfill_title_info.py --fill-pk --sleep 0.2"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
BJDONG_CODE_CSV = "법정동코드_전체자료.zip"
PUBLIC_BASE_URL = "https://homenstay.com"

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "app:app"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
