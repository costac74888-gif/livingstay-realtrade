modules = ["python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discover National"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Verify Units"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port app:app"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Discover National"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BJDONG_CODE_CSV=\"법정동코드_전체자료.zip\" bash -c \"python -u sync_batch.py --months 12 && python -u discover_new_buildings.py --region-offset 0 --region-limit 256 --months 12\""

[[workflows.workflow]]
name = "Verify Units"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -u verify_units.py excluded_small_buildings.csv"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
BJDONG_CODE_CSV = "법정동코드_전체자료.zip"
