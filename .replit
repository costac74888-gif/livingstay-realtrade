modules = ["python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Verify Units"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Reclassify"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port app:app"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Verify Units"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -u verify_units.py excluded_small_buildings.csv"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Reclassify"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BJDONG_CODE_CSV=\"attached_assets/법정동코드_전체자료_1783490670267.zip\" python -u reclassify_buildings.py --force --dry-run 2>&1 | tee /tmp/reclassify_dryrun.log"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
BJDONG_CODE_CSV = "법정동코드_전체자료.zip"
